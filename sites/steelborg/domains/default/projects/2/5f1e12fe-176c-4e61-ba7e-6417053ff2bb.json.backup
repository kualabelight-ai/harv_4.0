        },
        {
          "id": "block_new_block_1779779151_1",
          "fragment_name": "Алюминиевый_лист_рифленый_контроль_качества",
          "original_text": "Производственный процесс включает проверку сырья, контроль на каждом этапе обработки и тестирование готового изделия. Лист алюминия рифленый проходит строгую оценку для соответствия стандартам качества.",
          "processed_text": "Производственный процесс включает проверку сырья, контроль на каждом этапе обработки и тестирование готового изделия. Лист алюминия рифленый проходит строгую оценку для соответствия стандартам качества.",
          "html_text": "",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [],
