        },
        {
          "id": "block_new_block_1779778327_1",
          "fragment_name": "Алюминиевый_лист_рифленый_преимущества",
          "original_text": "Листовой алюминий рифленый обладает высокой устойчивостью к коррозии и механическим повреждениям. Он подходит для использования в строительстве, производстве и отделке благодаря легкости и простоте обработки.",
          "processed_text": "Листовой алюминий рифленый обладает высокой устойчивостью к коррозии и механическим повреждениям. Он подходит для использования в строительстве, производстве и отделке благодаря легкости и простоте обработки.",
          "html_text": "",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [],
          "manually_fixed": false,
          "warnings": [],
          "status": "processed",
          "manual_correction": null,
          "auto_corrected": false,
