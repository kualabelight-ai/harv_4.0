        },
        {
          "id": "block_description_template_1",
          "fragment_name": "Алюминиевый_лист_рифленый_описание",
          "original_text": "Лист алюминия рифленый имеет текстурированную поверхность, что улучшает сцепление и предотвращает скольжение. Он используется в строительстве, производстве и отделке. Конструктивная схема включает ребра жесткости, которые повышают устойчивость к механическим воздействиям.",
          "processed_text": "Лист алюминия рифленый имеет текстурированную поверхность, что улучшает сцепление и предотвращает скольжение. Он используется в строительстве, производстве и отделке. Конструктивная схема включает ребра жесткости, которые повышают устойчивость к механическим воздействиям.",
          "html_text": "",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [],
          "manually_fixed": false,
          "warnings": [],
          "status": "processed",
          "manual_correction": null,
          "auto_corrected": false,
