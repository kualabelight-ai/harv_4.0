          "last_modified": "2026-06-20T16:21:44.970467"
        },
        {
          "id": "block_new_block_1779776713_1",
          "fragment_name": "Алюминиевый_лист_рифленый_свойства",
          "original_text": "Материал сохраняет устойчивость к коррозии, механическим повреждениям, а также легкость в обработке. Алюминий рифленый подходит для использования в строительстве, производстве и отделке.",
          "processed_text": "Материал сохраняет устойчивость к коррозии, механическим повреждениям, а также легкость в обработке. Алюминий рифленый подходит для использования в строительстве, производстве и отделке.",
          "html_text": "",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [],
