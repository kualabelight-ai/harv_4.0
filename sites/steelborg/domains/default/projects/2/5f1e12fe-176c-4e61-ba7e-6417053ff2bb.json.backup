        },
        {
          "id": "block_new_block_1779779413_1",
          "fragment_name": "Алюминиевый_лист_рифленый_хранение_товара",
          "original_text": "Рифленый алюминий упаковывается в защитную пленку или картонные коробки, что предотвращает повреждения во время транспортировки. Хранить материал следует в сухом помещении, вдали от источников влаги и прямых солнечных лучей. Это поможет сохранить его свойства и внешний вид на длительный срок.",
          "processed_text": "Рифленый алюминий упаковывается в защитную пленку или картонные коробки, что предотвращает повреждения во время транспортировки. Хранить материал следует в сухом помещении, вдали от источников влаги и прямых солнечных лучей. Это поможет сохранить его свойства и внешний вид на длительный срок.",
          "html_text": "",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [],
          "manually_fixed": false,
          "warnings": [],
