        },
        {
          "id": "block_new_block_1779778987_1",
          "fragment_name": "Алюминиевый_лист_рифленый_обработка",
          "original_text": "Перед использованием изделия необходимо очистить поверхность от загрязнений. Затем рекомендуется обработать рифленые участки специальным средством для защиты от коррозии.",
          "processed_text": "Перед использованием изделия необходимо очистить поверхность от загрязнений. Затем рекомендуется обработать рифленые участки специальным средством для защиты от коррозии.",
          "html_text": "",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [],
          "manually_fixed": false,
          "warnings": [],
