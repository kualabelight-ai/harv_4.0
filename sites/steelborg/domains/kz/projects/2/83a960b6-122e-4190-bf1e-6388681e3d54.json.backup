        },
        {
          "id": "char_00003987_темно-зеленая_2",
          "fragment_name": "Сетка_рабица_Цвет_темно_зеленая",
          "original_text": "Изделие выполнено в темно-зеленом цвете, что способствует эффективной терморегуляции. Такой оттенок помогает снизить нагрев материала на солнце, обеспечивая комфортные условия эксплуатации.",
          "processed_text": "Изделие выполнено в темно-зеленом цвете, что способствует эффективной терморегуляции. Такой оттенок помогает снизить нагрев материала на солнце, обеспечивая комфортные условия эксплуатации.",
          "html_text": "<p>Изделие выполнено в темно-зеленом цвете, что способствует эффективной терморегуляции. Такой оттенок помогает снизить нагрев материала на солнце, обеспечивая комфортные условия эксплуатации.</p>\n<br>",
          "block_type": "unique",
          "characteristic_name": "Цвет",
          "characteristic_value": "темно-зеленая",
          "errors": [],
          "manually_fixed": true,
          "warnings": [],
          "status": "fixed",
          "manual_correction": null,
          "auto_corrected": false,
          "added_value": null,
