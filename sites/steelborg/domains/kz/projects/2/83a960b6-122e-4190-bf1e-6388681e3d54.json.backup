        },
        {
          "id": "char_00003987_светло-зеленая_2",
          "fragment_name": "Сетка_рабица_Цвет_светло_зеленая",
          "original_text": "Продукция представлена в светло-зеленом цвете, который часто выбирают для ограждений в саду и на даче. Такой оттенок гармонично вписывается в природный ландшафт, создавая уютную атмосферу.",
          "processed_text": "Продукция представлена в светло-зеленом цвете, который часто выбирают для ограждений в саду и на даче. Такой оттенок гармонично вписывается в природный ландшафт, создавая уютную атмосферу.",
          "html_text": "<p>Продукция представлена в светло-зеленом цвете, который часто выбирают для ограждений в саду и на даче. Такой оттенок гармонично вписывается в природный ландшафт, создавая уютную атмосферу.</p>\n<br>",
          "block_type": "unique",
          "characteristic_name": "Цвет",
          "characteristic_value": "светло-зеленая",
          "errors": [],
          "manually_fixed": true,
          "warnings": [],
          "status": "fixed",
          "manual_correction": null,
          "auto_corrected": false,
          "added_value": null,
