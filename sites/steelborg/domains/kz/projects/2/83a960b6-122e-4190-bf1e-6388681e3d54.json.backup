        },
        {
          "id": "char_00003987_хаки_1",
          "fragment_name": "Сетка_рабица_Цвет_хаки",
          "original_text": "Сеть рабица в цвете хаки гармонично вписывается в природный ландшафт, что позволяет снизить визуальную нагрузку на окружающую среду. Такой оттенок отражает солнечные лучи, уменьшая нагрев материала и продлевая срок его службы.",
          "processed_text": "Сеть рабица в цвете хаки гармонично вписывается в природный ландшафт, что позволяет снизить визуальную нагрузку на окружающую среду. Такой оттенок отражает солнечные лучи, уменьшая нагрев материала и продлевая срок его службы.",
          "html_text": "<p>Сеть рабица в цвете хаки гармонично вписывается в природный ландшафт, что позволяет снизить визуальную нагрузку на окружающую среду. Такой оттенок отражает солнечные лучи, уменьшая нагрев материала и продлевая срок его службы.</p>\n<br>",
          "block_type": "unique",
          "characteristic_name": "Цвет",
          "characteristic_value": "хаки",
          "errors": [],
          "manually_fixed": true,
          "warnings": [],
          "status": "fixed",
          "manual_correction": null,
          "auto_corrected": false,
