        },
        {
          "id": "char_00003987_желтая_3",
          "fragment_name": "Сетка_рабица_Цвет_желтая",
          "original_text": "Изделие выполнено из рабицы желтого цвета, что создает яркий акцент в ландшафтном дизайне и визуально расширяет пространство, придавая окружающей среде солнечное настроение.",
          "processed_text": "Изделие выполнено из рабицы желтого цвета, что создает яркий акцент в ландшафтном дизайне и визуально расширяет пространство, придавая окружающей среде солнечное настроение.",
          "html_text": "<p>Изделие выполнено из рабицы желтого цвета, что создает яркий акцент в ландшафтном дизайне и визуально расширяет пространство, придавая окружающей среде солнечное настроение.</p>\n<br>",
          "block_type": "unique",
          "characteristic_name": "Цвет",
          "characteristic_value": "желтая",
