        },
        {
          "id": "block_new_block_1779779151_9",
          "fragment_name": "Сетка_рабица_контроль_качества",
          "original_text": "Контроль качества начинается с выбора сырья. Затем проводится проверка на соответствие стандартам, а в финале готовая продукция проходит тестирование перед упаковкой.",
          "processed_text": "Контроль качества начинается с выбора сырья. Затем проводится проверка на соответствие стандартам, а в финале готовая продукция проходит тестирование перед упаковкой.",
          "html_text": "<p>Контроль качества начинается с выбора сырья. Затем проводится проверка на соответствие стандартам, а в финале готовая продукция проходит тестирование перед упаковкой.</p>\n<br>",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [],
          "manually_fixed": true,
          "warnings": [],
          "status": "fixed",
          "manual_correction": null,
          "auto_corrected": false,
