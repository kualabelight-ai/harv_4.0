        },
        {
          "id": "char_00003987_серая_3",
          "fragment_name": "Сетка_рабица_Цвет_серая",
          "original_text": "Продукция в сером цвете гармонично вписывается в ландшафт, создавая спокойную атмосферу. Такой оттенок способствует визуальному единству с природой и подходит для различных стилей оформления.",
          "processed_text": "Продукция в сером цвете гармонично вписывается в ландшафт, создавая спокойную атмосферу. Такой оттенок способствует визуальному единству с природой и подходит для различных стилей оформления.",
          "html_text": "<p>Продукция в сером цвете гармонично вписывается в ландшафт, создавая спокойную атмосферу. Такой оттенок способствует визуальному единству с природой и подходит для различных стилей оформления.</p>\n<br>",
          "block_type": "unique",
          "characteristic_name": "Цвет",
          "characteristic_value": "серая",
          "errors": [],
          "manually_fixed": true,
          "warnings": [],
          "status": "fixed",
          "manual_correction": null,
