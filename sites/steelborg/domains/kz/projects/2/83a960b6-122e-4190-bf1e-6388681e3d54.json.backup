        },
        {
          "id": "char_00003985_с полимерным покрытием_4",
          "fragment_name": "Сетка_рабица_Покрытие_с_полимерным_покрытием",
          "original_text": "Продукция с полимерным покрытием защищает от коррозии, что значительно увеличивает срок службы в условиях повышенной влажности или агрессивной среды. Такой вариант подходит для использования в различных климатических зонах.",
          "processed_text": "Продукция с полимерным покрытием защищает от коррозии, что значительно увеличивает срок службы в условиях повышенной влажности или агрессивной среды. Такой вариант подходит для использования в различных климатических зонах.",
          "html_text": "<p>Продукция с полимерным покрытием защищает от коррозии, что значительно увеличивает срок службы в условиях повышенной влажности или агрессивной среды. Такой вариант подходит для использования в различных климатических зонах.</p>\n<br>",
          "block_type": "unique",
          "characteristic_name": "Покрытие",
          "characteristic_value": "с полимерным покрытием",
          "errors": [],
          "manually_fixed": true,
