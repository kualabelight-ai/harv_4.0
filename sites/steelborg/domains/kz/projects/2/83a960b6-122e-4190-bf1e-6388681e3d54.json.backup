        {
          "id": "char_00003985_с полимерным покрытием_2",
          "fragment_name": "Сетка_рабица_Покрытие_с_полимерным_покрытием",
          "original_text": "Покрытие из полимера защищает рабица от коррозии и механических повреждений, что делает использование в агрессивных средах безопасным. Это свойство увеличивает срок службы материала и снижает риск повреждений.",
          "processed_text": "Покрытие из полимера защищает рабица от коррозии и механических повреждений, что делает использование в агрессивных средах безопасным. Это свойство увеличивает срок службы материала и снижает риск повреждений.",
          "html_text": "<p>Покрытие из полимера защищает рабица от коррозии и механических повреждений, что делает использование в агрессивных средах безопасным. Это свойство увеличивает срок службы материала и снижает риск повреждений.</p>\n<br>",
          "block_type": "unique",
          "characteristic_name": "Покрытие",
          "characteristic_value": "с полимерным покрытием",
          "errors": [],
          "manually_fixed": true,
          "warnings": [],
          "status": "fixed",
          "manual_correction": null,
          "auto_corrected": false,
          "added_value": null,
