        },
        {
          "id": "block_new_block_1779778987_6",
          "fragment_name": "Сетка_рабица_обработка",
          "original_text": "Изделие проходит антикоррозийную обработку, что увеличивает срок службы. Использование полимерных покрытий защищает от воздействия внешней среды, а также предотвращает образование ржавчины.",
          "processed_text": "Изделие проходит антикоррозийную обработку, что увеличивает срок службы. Использование полимерных покрытий защищает от воздействия внешней среды, а также предотвращает образование ржавчины.",
          "html_text": "<p>Изделие проходит антикоррозийную обработку, что увеличивает срок службы. Использование полимерных покрытий защищает от воздействия внешней среды, а также предотвращает образование ржавчины.</p>\n<br>",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [],
          "manually_fixed": true,
          "warnings": [],
          "status": "fixed",
