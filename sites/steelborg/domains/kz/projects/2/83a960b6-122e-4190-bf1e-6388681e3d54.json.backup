          "last_modified": "2026-06-23T10:37:10.232660"
        },
        {
          "id": "char_00003987_серая_2",
          "fragment_name": "Сетка_рабица_Цвет_серая",
          "original_text": "Сеть рабица в сером цвете отличается стойкостью к внешним воздействиям. Такой оттенок не только гармонично вписывается в ландшафт, но и защищает от коррозии, что увеличивает срок службы изделия.",
          "processed_text": "Сеть рабица в сером цвете отличается стойкостью к внешним воздействиям. Такой оттенок не только гармонично вписывается в ландшафт, но и защищает от коррозии, что увеличивает срок службы изделия.",
          "html_text": "<p>Сеть рабица в сером цвете отличается стойкостью к внешним воздействиям. Такой оттенок не только гармонично вписывается в ландшафт, но и защищает от коррозии, что увеличивает срок службы изделия.</p>\n<br>",
          "block_type": "unique",
          "characteristic_name": "Цвет",
          "characteristic_value": "серая",
          "errors": [],
          "manually_fixed": true,
          "warnings": [],
          "status": "fixed",
          "manual_correction": null,
          "auto_corrected": false,
          "added_value": null,
          "special_symbols": [],
