        },
        {
          "id": "char_00003987_хаки_2",
          "fragment_name": "Сетка_рабица_Цвет_хаки",
          "original_text": "Сеть рабица в оттенке хаки снижает заметность конструкции для животных и людей, что делает ее подходящей для ограждений в природных условиях. Такой цвет гармонично вписывается в окружающий ландшафт.",
          "processed_text": "Сеть рабица в оттенке хаки снижает заметность конструкции для животных и людей, что делает ее подходящей для ограждений в природных условиях. Такой цвет гармонично вписывается в окружающий ландшафт.",
          "html_text": "<p>Сеть рабица в оттенке хаки снижает заметность конструкции для животных и людей, что делает ее подходящей для ограждений в природных условиях. Такой цвет гармонично вписывается в окружающий ландшафт.</p>\n<br>",
          "block_type": "unique",
          "characteristic_name": "Цвет",
          "characteristic_value": "хаки",
          "errors": [],
          "manually_fixed": true,
          "warnings": [],
          "status": "fixed",
          "manual_correction": null,
          "auto_corrected": false,
