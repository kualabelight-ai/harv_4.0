        },
        {
          "id": "char_00003987_светло-зеленая_1",
          "fragment_name": "Сетка_рабица_Цвет_светло_зеленая",
          "original_text": "Ограждение из рабицы светло-зеленого цвета гармонично вписывается в природный ландшафт, создавая ощущение легкости и свежести, что способствует улучшению визуального восприятия пространства.",
          "processed_text": "Ограждение из рабицы светло-зеленого цвета гармонично вписывается в природный ландшафт, создавая ощущение легкости и свежести, что способствует улучшению визуального восприятия пространства.",
          "html_text": "<p>Ограждение из рабицы светло-зеленого цвета гармонично вписывается в природный ландшафт, создавая ощущение легкости и свежести, что способствует улучшению визуального восприятия пространства.</p>\n<br>",
          "block_type": "unique",
          "characteristic_name": "Цвет",
          "characteristic_value": "светло-зеленая",
          "errors": [],
          "manually_fixed": true,
          "warnings": [],
          "status": "fixed",
          "manual_correction": null,
          "auto_corrected": false,
          "added_value": null,
