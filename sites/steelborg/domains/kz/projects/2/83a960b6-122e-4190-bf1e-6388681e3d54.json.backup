        },
        {
          "id": "block_new_block_1779776713_3",
          "fragment_name": "Сетка_рабица_свойства",
          "original_text": "Изделие сохраняет свои свойства при экстремальных температурах и выдерживает значительные механические нагрузки. Сеть рабица устойчива к деформациям, что позволяет использовать ее в различных условиях эксплуатации.",
          "processed_text": "Изделие сохраняет свои свойства при экстремальных температурах и выдерживает значительные механические нагрузки. Сеть рабица устойчива к деформациям, что позволяет использовать ее в различных условиях эксплуатации.",
          "html_text": "<p>Изделие сохраняет свои свойства при экстремальных температурах и выдерживает значительные механические нагрузки. Сеть рабица устойчива к деформациям, что позволяет использовать ее в различных условиях эксплуатации.</p>\n<br>",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [],
          "manually_fixed": true,
          "warnings": [],
          "status": "fixed",
