        },
        {
          "id": "char_00003987_красная_1",
          "fragment_name": "Сетка_рабица_Цвет_красная",
          "original_text": "Продукция представлена в красном цвете, что помогает четко обозначить границы участка. Яркий оттенок служит предупреждением о наличии ограждения, повышая безопасность и видимость.",
          "processed_text": "Продукция представлена в красном цвете, что помогает четко обозначить границы участка. Яркий оттенок служит предупреждением о наличии ограждения, повышая безопасность и видимость.",
          "html_text": "<p>Продукция представлена в красном цвете, что помогает четко обозначить границы участка. Яркий оттенок служит предупреждением о наличии ограждения, повышая безопасность и видимость.</p>\n<br>",
          "block_type": "unique",
          "characteristic_name": "Цвет",
          "characteristic_value": "красная",
          "errors": [],
          "manually_fixed": true,
          "warnings": [],
          "status": "fixed",
          "manual_correction": null,
          "auto_corrected": false,
          "added_value": null,
