        },
        {
          "id": "block_new_block_1779776713_1",
          "fragment_name": "Известковый_раствор_свойства",
          "original_text": "Известняковый раствор обладает высокой адгезией и хорошей воздухопроницаемостью. Он демонстрирует отличные теплоизоляционные свойства, что делает его подходящим для различных строительных задач. Кроме того, материал устойчив к воздействию влаги и химических веществ, что увеличивает его срок службы в условиях эксплуатации.",
          "processed_text": "Известняковый раствор обладает высокой адгезией и хорошей воздухопроницаемостью. Он демонстрирует отличные теплоизоляционные свойства, что делает его подходящим для различных строительных задач. Кроме того, материал устойчив к воздействию влаги и химических веществ, что увеличивает его срок службы в условиях эксплуатации.",
          "html_text": "",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [],
          "manually_fixed": false,
          "warnings": [],
          "status": "processed",
          "manual_correction": null,
          "auto_corrected": false,
