        {
          "id": "block_production_description_template_1",
          "fragment_name": "Известковый_раствор_производство",
          "original_text": "Качество сырья для раствора извести напрямую влияет на его характеристики. Использование высококачественных компонентов способствует созданию смеси, способной выдерживать нагрузки и сохранять свои свойства в течение длительного времени. Правильный выбор материалов гарантирует надежную основу для строительных проектов.",
          "processed_text": "Качество сырья для раствора извести напрямую влияет на его характеристики. Использование высококачественных компонентов способствует созданию смеси, способной выдерживать нагрузки и сохранять свои свойства в течение длительного времени. Правильный выбор материалов гарантирует надежную основу для строительных проектов.",
          "html_text": "",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [],
          "manually_fixed": false,
          "warnings": [],
          "status": "processed",
          "manual_correction": null,
          "auto_corrected": false,
          "added_value": null,
          "special_symbols": [],
