        },
        {
          "id": "block_new_block_1779778598_1",
          "fragment_name": "Известковый_раствор_разновидности",
          "original_text": "Изделие классифицируется по составу, назначению и способу применения. В зависимости от этих факторов выделяют растворы для строительных работ, отделки или специальных задач. Раствор извести подходит для создания прочных конструкций и улучшения теплоизоляции.",
          "processed_text": "Изделие классифицируется по составу, назначению и способу применения. В зависимости от этих факторов выделяют растворы для строительных работ, отделки или специальных задач. Раствор извести подходит для создания прочных конструкций и улучшения теплоизоляции.",
          "html_text": "",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [],
