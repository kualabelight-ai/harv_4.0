        },
        {
          "id": "block_new_block_1779779151_1",
          "fragment_name": "Известковый_раствор_контроль_качества",
          "original_text": "При производстве раствора извести допускаются небольшие отклонения в консистенции и цвете. Однако значительные изменения, такие как наличие крупных частиц или неравномерная текстура, требуют отбраковки. Качество смеси влияет на ее применение в строительстве и ремонте.",
          "processed_text": "При производстве раствора извести допускаются небольшие отклонения в консистенции и цвете. Однако значительные изменения, такие как наличие крупных частиц или неравномерная текстура, требуют отбраковки. Качество смеси влияет на ее применение в строительстве и ремонте.",
          "html_text": "",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [],
