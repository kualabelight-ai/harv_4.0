        },
        {
          "id": "block_product_header_template_1",
          "fragment_name": "Известковый_раствор_заголовок",
          "original_text": "Качественный строительный состав [название товара] за [цена] в наличии. Быстрая доставка по [город]. При покупке больших объемов — выгодные бонусы!",
          "processed_text": "Качественный строительный состав [название товара] за [цена] в наличии. Быстрая доставка по [город]. При покупке больших объемов — выгодные бонусы!",
