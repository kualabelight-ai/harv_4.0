        },
        {
          "id": "block_new_block_1779778327_1",
          "fragment_name": "Известковый_раствор_преимущества",
          "original_text": "Раствор на основе извести отличается от альтернативных смесей своей способностью к паропроницаемости и экологичности. Он способствует созданию здорового микроклимата в помещениях, предотвращая накопление влаги. Такой состав подходит для отделки стен и потолков, обеспечивая надежное сцепление с различными поверхностями.",
          "processed_text": "Раствор на основе извести отличается от альтернативных смесей своей способностью к паропроницаемости и экологичности. Он способствует созданию здорового микроклимата в помещениях, предотвращая накопление влаги. Такой состав подходит для отделки стен и потолков, обеспечивая надежное сцепление с различными поверхностями.",
          "html_text": "",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [],
          "manually_fixed": false,
          "warnings": [],
