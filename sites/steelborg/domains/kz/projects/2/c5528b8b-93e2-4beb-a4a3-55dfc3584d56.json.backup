          "manual_correction": null,
          "auto_corrected": false,
          "added_value": null,
          "special_symbols": [],
          "last_modified": "2026-06-21T18:26:44.549668"
        },
        {
          "id": "block_new_block_1779778817_1",
          "fragment_name": "Известковый_раствор_подбор",
          "original_text": "При выборе известнякового раствора часто допускаются ошибки, связанные с неправильным определением необходимой консистенции. Неправильное соотношение компонентов может привести к снижению прочности и увеличению времени высыхания. Важно учитывать условия эксплуатации, чтобы избежать проблем в будущем.",
          "processed_text": "При выборе известнякового раствора часто допускаются ошибки, связанные с неправильным определением необходимой консистенции. Неправильное соотношение компонентов может привести к снижению прочности и увеличению времени высыхания. Важно учитывать условия эксплуатации, чтобы избежать проблем в будущем.",
          "html_text": "",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [],
          "manually_fixed": false,
          "warnings": [],
          "status": "processed",
          "manual_correction": null,
          "auto_corrected": false,
          "added_value": null,
