        },
        {
          "id": "char_00003707_горячекатаная_5",
          "fragment_name": "Труба_нержавеющая_Способ_производства_горячекатаная",
          "original_text": "Горячекатаная конструкция из нержавеющей стали обладает улучшенными механическими свойствами благодаря высокой температуре обработки, что способствует равномерному распределению напряжений. Такой метод производства повышает устойчивость к коррозии и механическим повреждениям.",
          "processed_text": "Горячекатаная конструкция из нержавеющей стали обладает улучшенными механическими свойствами благодаря высокой температуре обработки, что способствует равномерному распределению напряжений. Такой метод производства повышает устойчивость к коррозии и механическим повреждениям.",
          "html_text": "<p>Горячекатаная конструкция из нержавеющей стали обладает улучшенными механическими свойствами благодаря высокой температуре обработки, что способствует равномерному распределению напряжений. Такой метод производства повышает устойчивость к коррозии и механическим повреждениям.</p>\n<br>",
          "block_type": "unique",
          "characteristic_name": "Способ производства",
          "characteristic_value": "горячекатаная",
          "errors": [],
          "manually_fixed": true,
          "warnings": [],
          "status": "fixed",
          "manual_correction": null,
          "auto_corrected": false,
