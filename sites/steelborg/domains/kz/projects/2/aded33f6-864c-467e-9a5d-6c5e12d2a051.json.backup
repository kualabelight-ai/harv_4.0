        },
        {
          "id": "char_00003707_горячекатаная_4",
          "fragment_name": "Труба_нержавеющая_Способ_производства_горячекатаная",
          "original_text": "Горячекатаная конструкция обладает высокой пластичностью, что упрощает процесс монтажа и обработки. Труба из нержавейки подходит для использования в условиях повышенной влажности, обеспечивая надежное соединение.",
          "processed_text": "Горячекатаная конструкция обладает высокой пластичностью, что упрощает процесс монтажа и обработки. Труба из нержавейки подходит для использования в условиях повышенной влажности, обеспечивая надежное соединение.",
          "html_text": "<p>Горячекатаная конструкция обладает высокой пластичностью, что упрощает процесс монтажа и обработки. Труба из нержавейки подходит для использования в условиях повышенной влажности, обеспечивая надежное соединение.</p>\n<br>",
          "block_type": "unique",
          "characteristic_name": "Способ производства",
          "characteristic_value": "горячекатаная",
          "errors": [],
          "manually_fixed": true,
