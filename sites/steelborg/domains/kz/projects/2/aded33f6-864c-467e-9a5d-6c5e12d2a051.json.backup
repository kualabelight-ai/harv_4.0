        },
        {
          "id": "char_00003707_горячекатаная_2",
          "fragment_name": "Труба_нержавеющая_Способ_производства_горячекатаная",
          "original_text": "Горячекатаная продукция отличается высокой пластичностью и однородной структурой, что снижает затраты на производство и делает ее более доступной по цене. Такой способ обработки позволяет добиться оптимальных механических свойств, что важно для многих применений.",
          "processed_text": "Горячекатаная продукция отличается высокой пластичностью и однородной структурой, что снижает затраты на производство и делает ее более доступной по цене. Такой способ обработки позволяет добиться оптимальных механических свойств, что важно для многих применений.",
          "html_text": "<p>Горячекатаная продукция отличается высокой пластичностью и однородной структурой, что снижает затраты на производство и делает ее более доступной по цене. Такой способ обработки позволяет добиться оптимальных механических свойств, что важно для многих применений.</p>\n<br>",
          "block_type": "unique",
          "characteristic_name": "Способ производства",
          "characteristic_value": "горячекатаная",
          "errors": [],
          "manually_fixed": true,
