        },
        {
          "id": "char_00003707_электросварная_4",
          "fragment_name": "Труба_нержавеющая_Способ_производства_электросварная",
          "original_text": "Электросварная конструкция из нержавеющей стали обладает высокой устойчивостью к коррозии и механическим повреждениям. Такой способ производства улучшает характеристики, что позволяет использовать изделие в агрессивных средах.",
          "processed_text": "Электросварная конструкция из нержавеющей стали обладает высокой устойчивостью к коррозии и механическим повреждениям. Такой способ производства улучшает характеристики, что позволяет использовать изделие в агрессивных средах.",
          "html_text": "<p>Электросварная конструкция из нержавеющей стали обладает высокой устойчивостью к коррозии и механическим повреждениям. Такой способ производства улучшает характеристики, что позволяет использовать изделие в агрессивных средах.</p>\n<br>",
          "block_type": "unique",
          "characteristic_name": "Способ производства",
          "characteristic_value": "электросварная",
          "errors": [],
          "manually_fixed": true,
          "warnings": [],
          "status": "fixed",
          "manual_correction": null,
          "auto_corrected": false,
          "added_value": null,
