          "last_modified": "2026-06-25T10:16:50.265572"
        },
        {
          "id": "char_00003707_холоднокатаная_3",
          "fragment_name": "Труба_нержавеющая_Способ_производства_холоднокатаная",
          "original_text": "Холоднокатаная стальная нержавеющая конструкция подходит для эксплуатации в агрессивных средах. Учитывайте способ производства при выборе, чтобы гарантировать соответствие требованиям конкретных условий.",
          "processed_text": "Холоднокатаная стальная нержавеющая конструкция подходит для эксплуатации в агрессивных средах. Учитывайте способ производства при выборе, чтобы гарантировать соответствие требованиям конкретных условий.",
          "html_text": "<p>Холоднокатаная стальная нержавеющая конструкция подходит для эксплуатации в агрессивных средах. Учитывайте способ производства при выборе, чтобы гарантировать соответствие требованиям конкретных условий.</p>\n<br>",
          "block_type": "unique",
          "characteristic_name": "Способ производства",
          "characteristic_value": "холоднокатаная",
          "errors": [],
          "manually_fixed": true,
          "warnings": [],
          "status": "fixed",
          "manual_correction": null,
          "auto_corrected": false,
          "added_value": null,
