        },
        {
          "id": "block_new_block_1779779151_11",
          "fragment_name": "Труба_нержавеющая_контроль_качества",
          "original_text": "При поверхностном осмотре можно выявить явные дефекты, такие как коррозия или механические повреждения. Для оценки качества партии требуется проведение выборочных испытаний, особенно если труба из нержавеющей стали предназначена для ответственных конструкций.",
          "processed_text": "При поверхностном осмотре можно выявить явные дефекты, такие как коррозия или механические повреждения. Для оценки качества партии требуется проведение выборочных испытаний, особенно если труба из нержавеющей стали предназначена для ответственных конструкций.",
          "html_text": "<p>При поверхностном осмотре можно выявить явные дефекты, такие как коррозия или механические повреждения. Для оценки качества партии требуется проведение выборочных испытаний, особенно если труба из нержавеющей стали предназначена для ответственных конструкций.</p>\n<br>",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [],
          "manually_fixed": true,
          "warnings": [],
          "status": "fixed",
          "manual_correction": null,
          "auto_corrected": false,
