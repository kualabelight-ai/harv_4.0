        },
        {
          "id": "block_new_block_1779778598_18",
          "fragment_name": "Труба_нержавеющая_разновидности",
          "original_text": "Сортамент изделий формируется по диаметрам, толщине стенок и длине. Труба стальная нержавеющая представлена в различных размерах, что позволяет выбрать подходящий вариант для конкретных задач.",
          "processed_text": "Сортамент изделий формируется по диаметрам, толщине стенок и длине. Труба стальная нержавеющая представлена в различных размерах, что позволяет выбрать подходящий вариант для конкретных задач.",
          "html_text": "<p>Сортамент изделий формируется по диаметрам, толщине стенок и длине. Труба стальная нержавеющая представлена в различных размерах, что позволяет выбрать подходящий вариант для конкретных задач.</p>\n<br>",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [],
          "manually_fixed": true,
          "warnings": [],
          "status": "fixed",
          "manual_correction": null,
          "auto_corrected": false,
