        },
        {
          "id": "char_00003707_горячекатаная_3",
          "fragment_name": "Труба_нержавеющая_Способ_производства_горячекатаная",
          "original_text": "Горячекатаная стальная нержавеющая конструкция обладает улучшенными механическими свойствами благодаря равномерной структуре. Такой способ производства обеспечивает высокую стойкость к коррозии и повышает эксплуатационные характеристики.",
          "processed_text": "Горячекатаная стальная нержавеющая конструкция обладает улучшенными механическими свойствами благодаря равномерной структуре. Такой способ производства обеспечивает высокую стойкость к коррозии и повышает эксплуатационные характеристики.",
          "html_text": "<p>Горячекатаная стальная нержавеющая конструкция обладает улучшенными механическими свойствами благодаря равномерной структуре. Такой способ производства обеспечивает высокую стойкость к коррозии и повышает эксплуатационные характеристики.</p>\n<br>",
          "block_type": "unique",
          "characteristic_name": "Способ производства",
          "characteristic_value": "горячекатаная",
          "errors": [],
          "manually_fixed": true,
