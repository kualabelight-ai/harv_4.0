        },
        {
          "id": "block_description_template_5",
          "fragment_name": "Труба_нержавеющая_описание",
          "original_text": "Выбор стальной нержавеющей трубы гарантирует устойчивость к коррозии и механическим повреждениям. Такие изделия служат долго, не теряя функциональности. Они подходят для различных условий эксплуатации, включая агрессивные среды.",
          "processed_text": "Выбор стальной нержавеющей трубы гарантирует устойчивость к коррозии и механическим повреждениям. Такие изделия служат долго, не теряя функциональности. Они подходят для различных условий эксплуатации, включая агрессивные среды.",
          "html_text": "<p>Выбор стальной нержавеющей трубы гарантирует устойчивость к коррозии и механическим повреждениям. Такие изделия служат долго, не теряя функциональности. Они подходят для различных условий эксплуатации, включая агрессивные среды.</p>\n<br>",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [],
          "manually_fixed": true,
          "warnings": [],
