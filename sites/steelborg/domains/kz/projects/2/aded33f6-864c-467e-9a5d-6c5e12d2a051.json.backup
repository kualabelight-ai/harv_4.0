        },
        {
          "id": "block_description_template_7",
          "fragment_name": "Труба_нержавеющая_описание",
          "original_text": "Изделие из нержавеющей стали подходит для использования в условиях высокой влажности и коррозии. Возможности сварки позволяют создавать конструкции различной сложности, обеспечивая надежное соединение элементов.",
          "processed_text": "Изделие из нержавеющей стали подходит для использования в условиях высокой влажности и коррозии. Возможности сварки позволяют создавать конструкции различной сложности, обеспечивая надежное соединение элементов.",
          "html_text": "<p>Изделие из нержавеющей стали подходит для использования в условиях высокой влажности и коррозии. Возможности сварки позволяют создавать конструкции различной сложности, обеспечивая надежное соединение элементов.</p>\n<br>",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [],
          "manually_fixed": true,
