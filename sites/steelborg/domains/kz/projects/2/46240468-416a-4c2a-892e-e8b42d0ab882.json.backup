        },
        {
          "id": "block_product_header_template_1",
          "fragment_name": "Прогон_железобетонный_заголовок",
          "original_text": "Заголовок: [название товара] — всего [цена] за единицу, быстрая обработка заказов, экономия при опте в [город].",
          "processed_text": "Качественный [название товара] доступен от [цена]. Оперативная поставка гарантирует быстрое получение. При заказе больших объемов предусмотрено снижение цены, что позволяет сэкономить. Доставка в [город].",
          "html_text": "",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [
            {
              "type": "unwanted_brackets",
