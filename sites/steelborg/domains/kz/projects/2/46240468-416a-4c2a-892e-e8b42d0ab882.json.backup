        },
        {
          "id": "block_text_description_template_1",
          "fragment_name": "Прогон_железобетонный_применение_текст",
          "original_text": "<h2>Применение на промышленных площадках</h2>\n\nИспользуется для создания опорных конструкций на заводах и в производственных зонах. Часто применяется в сочетании со шпалой жби для формирования устойчивых оснований под оборудование. Подходит для монтажа в условиях высокой нагрузки.",
          "processed_text": "<h2>Применение в различных сферах</h2>  \nТруба из нержавейки используется в строительстве, сантехнике, пищевой промышленности. Она устойчива к коррозии, что делает ее подходящей для систем водоснабжения и отопления. Также применяется в производстве оборудования для переработки продуктов, обеспечивая безопасность и гигиеничность.",
          "html_text": "",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [
            {
              "type": "special_symbol",
              "message": "Найдены специальные символы: <, /, >"
            }
          ],
          "manually_fixed": false,
          "warnings": [],
          "status": "error",
          "manual_correction": null,
          "auto_corrected": false,
          "added_value": null,
          "special_symbols": [
            [
              "<",
              0,
              1
            ],
            [
              ">",
              3,
              4
            ],
            [
              "<",
              40,
              41
            ],
            [
              "/",
              41,
