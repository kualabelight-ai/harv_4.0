          "special_symbols": [],
          "last_modified": "2026-06-22T12:49:55.584198"
        },
        {
          "id": "block_new_block_1779778327_1",
          "fragment_name": "Известковый_раствор_преимущества",
          "original_text": "Раствор извести подходит для создания прочных и устойчивых к воздействию внешней среды конструкций. Он обладает высокой паропроницаемостью, что предотвращает накопление влаги. В отличие от альтернатив, этот материал не подвержен гниению и образованию плесени.",
          "processed_text": "Раствор извести подходит для создания прочных и устойчивых к воздействию внешней среды конструкций. Он обладает высокой паропроницаемостью, что предотвращает накопление влаги. В отличие от альтернатив, этот материал не подвержен гниению и образованию плесени.",
          "html_text": "",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [],
          "manually_fixed": false,
          "warnings": [],
          "status": "processed",
          "manual_correction": null,
          "auto_corrected": false,
          "added_value": null,
          "special_symbols": [],
          "last_modified": "2026-06-22T12:49:55.585237"
        },
        {
          "id": "block_new_block_1779778598_1",
          "fragment_name": "Известковый_раствор_разновидности",
          "original_text": "Раствор извести классифицируется по нескольким признакам, включая состав и назначение. В зависимости от содержания активных компонентов выделяют гидратированную и негидратированную формы. Также важна область применения, например, для строительных или отделочных работ.",
          "processed_text": "Раствор извести классифицируется по нескольким признакам, включая состав и назначение. В зависимости от содержания активных компонентов выделяют гидратированную и негидратированную формы. Также важна область применения, например, для строительных или отделочных работ.",
          "html_text": "",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [],
          "manually_fixed": false,
          "warnings": [],
          "status": "processed",
          "manual_correction": null,
          "auto_corrected": false,
          "added_value": null,
          "special_symbols": [],
          "last_modified": "2026-06-22T12:49:55.585237"
        },
        {
          "id": "block_new_block_1779778817_1",
          "fragment_name": "Известковый_раствор_подбор",
          "original_text": "Для создания качественного строительного раствора важно учитывать состав и пропорции компонентов. Обратитесь к эксперту, если требуется известняковый раствор для специфических условий или сложных проектов.",
          "processed_text": "Для создания качественного строительного раствора важно учитывать состав и пропорции компонентов. Обратитесь к эксперту, если требуется известняковый раствор для специфических условий или сложных проектов.",
          "html_text": "",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
