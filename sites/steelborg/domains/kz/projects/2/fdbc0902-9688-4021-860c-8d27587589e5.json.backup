        },
        {
          "id": "block_new_block_1779779151_1",
          "fragment_name": "Известковый_раствор_контроль_качества",
          "original_text": "Раствор извести используется в строительстве для создания прочных и устойчивых конструкций. Перед продажей необходимо провести тесты на соответствие стандартам, проверить уровень pH, а также убедиться в отсутствии посторонних примесей. Эти проверки гарантируют безопасность и качество продукта.",
          "processed_text": "Раствор извести используется в строительстве для создания прочных и устойчивых конструкций. Перед продажей необходимо провести тесты на соответствие стандартам, проверить уровень pH, а также убедиться в отсутствии посторонних примесей. Эти проверки гарантируют безопасность и качество продукта.",
          "html_text": "",
          "block_type": "other",
          "characteristic_name": "",
          "characteristic_value": "",
          "errors": [],
