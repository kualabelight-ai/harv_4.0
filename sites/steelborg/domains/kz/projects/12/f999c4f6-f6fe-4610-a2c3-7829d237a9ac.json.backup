            ],
            "manually_fixed": true,
            "warnings": [],
            "status": "error",
            "manual_correction": null,
            "auto_corrected": true,
            "added_value": "ВА",
            "special_symbols": [],
            "last_modified": "2026-05-29T12:06:50.811995"
          },
          {
            "id": "char_00005142_ВА_2",
            "fragment_name": "Фольга_вольфрамовая_Марка_материала",
            "original_text": "Выбор марки вольфрамовой фольги зависит от таких факторов, как температура эксплуатации, механические нагрузки, а также требования к коррозионной стойкости для конкретных инженерных решений.",
            "processed_text": "Выбор марки вольфрамовой фольги зависит от таких факторов, как температура эксплуатации, механические нагрузки, а также требования к коррозионной стойкости для конкретных инженерных решений.",
            "html_text": "<p>Выбор марки вольфрамовой фольги зависит от таких факторов, как температура эксплуатации, механические нагрузки, а также требования к коррозионной стойкости для конкретных инженерных решений.</p>\n<br>",
            "block_type": "regular",
            "characteristic_name": "Марка материала",
