    "phase7_projects_data": {
      "f999c4f6-f6fe-4610-a2c3-7829d237a9ac": {
        "fragments_count": 3,
        "fragment_names": [
          "Фольга_вольфрамовая_Марка_материала"
        ],
        "category_code": "Фольга вольфрамовая",
        "last_modified": "2026-05-29T12:06:55.602036",
        "blocks": [
          {
            "id": "char_00005142_ВА_1",
            "fragment_name": "Фольга_вольфрамовая_Марка_материала",
            "original_text": "Материал с маркой ВА, обладая высокой температурной устойчивостью и низким коэффициентом теплового расширения, позволяет эффективно использовать фольгу из вольфрама в высокочастотных приложениях, таких как радиочастотные компоненты. Это делает его подходящим для задач, требующих надежности и стабильности в экстремальных условиях.",
            "processed_text": "Материал с маркой {prop Марка материала}, обладая высокой температурной устойчивостью и низким коэффициентом теплового расширения, позволяет эффективно использовать фольгу из вольфрама в высокочастотных приложениях, таких как радиочастотные компоненты. Это делает его подходящим для задач, требующих надежности и стабильности в экстремальных условиях.",
            "html_text": "<p>Материал с маркой {prop Марка материала}, обладая высокой температурной устойчивостью и низким коэффициентом теплового расширения, позволяет эффективно использовать фольгу из вольфрама в высокочастотных приложениях, таких как радиочастотные компоненты. Это делает его подходящим для задач, требующих надежности и стабильности в экстремальных условиях.</p>\n<br>",
            "block_type": "regular",
            "characteristic_name": "Марка материала",
            "characteristic_value": "ВА",
            "errors": [
              {
                "type": "stop_word_found",
                "message": "Найдено стоп-слово: \"приложен\""
